-- Function to get all valid targets in aura range
local function getAuraTargets()
    local targets = {}
    auraTargets = {}
    
    if not rootPart or not rootPart.Parent then return targets end
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") then
                local humanoid = otherChar.Humanoid
                if humanoid.Health > 0 then
                    local otherRoot = otherChar.HumanoidRootPart
                    local distance = (rootPart.Position - otherRoot.Position).Magnitude
                    
                    if distance <= AURA_MAX_DISTANCE then
                        table.insert(targets, {
                            player = otherPlayer,
                            character = otherChar,
                            rootPart = otherRoot,
                            humanoid = humanoid,
                            distance = distance
                        })
                        
                        table.insert(auraTargets, otherPlayer)
                    end
                end
            end
        end
    end
    
    -- Sort by distance (terdekat dulu)
    table.sort(targets, function(a, b)
        return a.distance < b.distance
    end)
    
    return targets
end

-- Function to damage target (Kill Aura)
local function damageTarget(target)
    if not target or not target.humanoid or target.humanoid.Health <= 0 then return end
    
    -- Coba berbagai method damage
    pcall(function()
        -- Method 1: Langsung set health ke 0
        target.humanoid.Health = 0
        
        -- Method 2: Break joints
        if target.humanoid:FindFirstChild("BreakJoints") then
            target.humanoid:BreakJoints()
        end
        
        -- Method 3: Fire takedown event (umum di game2)
        local args = {
            [1] = target.character,
            [2] = "Takedown"
        }
        local takedownEvent = ReplicatedStorage:FindFirstChild("Takedown") or 
                              ReplicatedStorage:FindFirstChild("Damage") or
                              ReplicatedStorage:FindFirstChild("Hit")
        if takedownEvent then
            takedownEvent:FireServer(unpack(args))
        end
        
        -- Method 4: Cari remote yang bisa dipake
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") and remote.Name:lower():find("damage") or 
               remote.Name:lower():find("hit") or 
               remote.Name:lower():find("attack") then
                remote:FireServer(target.character)
                break
            end
        end
    end)
    
    -- Efek visual kill
    if auraVisualEnabled then
        local killEffect = Instance.new("Part")
        killEffect.Size = Vector3.new(3, 3, 3)
        killEffect.Position = target.rootPart.Position
        killEffect.BrickColor = BrickColor.new("Really red")
        killEffect.Material = Enum.Material.Neon
        killEffect.CanCollide = false
        killEffect.Anchored = true
        killEffect.Parent = workspace
        killEffect.Transparency = 0.3
        killEffect.Shape = Enum.PartType.Ball
        
        game:GetService("Debris"):AddItem(killEffect, 0.3)
    end
end

-- Function to auto shoot target
local function shootTarget(target)
    if not target or not target.rootPart then return end
    
    local currentTime = tick()
    if currentTime - lastShootTime < SHOOT_COOLDOWN then return end
    lastShootTime = currentTime
    
    -- Simulate mouse click
    pcall(function()
        -- Method 1: Virtual click
        local mouse = player:GetMouse()
        if mouse then
            mouse1click() -- Untuk executor yang support
        end
        
        -- Method 2: Cari tool dan activate
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            local activateEvent = tool:FindFirstChild("Activate")
            if activateEvent and activateEvent:IsA("RemoteEvent") then
                activateEvent:FireServer()
            else
                -- Fallback: equip ulang
                tool.Parent = player.Backpack
                wait(0.1)
                tool.Parent = character
            end
        end
        
        -- Method 3: Cari weapon remote
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") then
                local remote = child:FindFirstChild("RemoteEvent") or 
                              child:FindFirstChild("Shoot") or 
                              child:FindFirstChild("Fire")
                if remote then
                    remote:FireServer()
                end
            end
        end
        
        -- Method 4: Click detector spam
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("ClickDetector") and part.Parent and part.Parent:IsDescendantOf(target.character) then
                fireclickdetector(part)
            end
        end
    end)
    
    -- Efek visual shoot
    if auraVisualEnabled then
        local shootEffect = Instance.new("Part")
        shootEffect.Size = Vector3.new(0.5, 0.5, 5)
        shootEffect.Position = rootPart.Position + camera.CFrame.LookVector * 3
        shootEffect.BrickColor = BrickColor.new("Bright yellow")
        shootEffect.Material = Enum.Material.Neon
        shootEffect.CanCollide = false
        shootEffect.Anchored = true
        shootEffect.Parent = workspace
        shootEffect.Transparency = 0.3
        shootEffect.Orientation = camera.CFrame.Rotation:ToEulerAnglesXYZ()
        
        game:GetService("Debris"):AddItem(shootEffect, 0.1)
    end
end

-- Function to update aura visual
local function updateAuraVisual()
    -- Clean up old visuals
    for _, part in ipairs(auraVisualParts) do
        if part and part.Parent then
            part:Destroy()
        end
    end
    auraVisualParts = {}
    
    if not auraVisualEnabled or not killAuraEnabled or not rootPart then return end
    
    -- Buat lingkaran aura
    local points = 20
    for i = 1, points do
        local angle = (i / points) * math.pi * 2
        local x = math.cos(angle) * AURA_MAX_DISTANCE
        local z = math.sin(angle) * AURA_MAX_DISTANCE
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.5, 0.5, 0.5)
        part.Position = rootPart.Position + Vector3.new(x, 0, z)
        part.BrickColor = BrickColor.new("Bright red")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
        part.Anchored = true
        part.Parent = workspace
        part.Transparency = 0.5
        
        table.insert(auraVisualParts, part)
    end
    
    -- Buat garis penghubung ke target
    for _, target in ipairs(getAuraTargets()) do
        local linePart = Instance.new("Part")
        linePart.Size = Vector3.new(0.2, 0.2, target.distance)
        linePart.Position = rootPart.Position + (target.rootPart.Position - rootPart.Position)/2
        linePart.CFrame = CFrame.lookAt(linePart.Position, target.rootPart.Position)
        linePart.BrickColor = BrickColor.new("Really red")
        linePart.Material = Enum.Material.Neon
        linePart.CanCollide = false
        linePart.Anchored = true
        linePart.Parent = workspace
        linePart.Transparency = 0.3
        
        table.insert(auraVisualParts, linePart)
    end
end

