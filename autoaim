-- Blink Functions
local function blinkDown(studs)
    if rootPart and rootPart.Parent then
        local newPos = rootPart.Position - Vector3.new(0, studs, 0)
        
        -- Cek collision sederhana
        local ray = Ray.new(rootPart.Position, Vector3.new(0, -studs, 0))
        local hit, position = workspace:FindPartOnRay(ray, character)
        
        if hit then
            newPos = position + Vector3.new(0, 3, 0)
        end
        
        -- Tween untuk efek halus
        local tween = TweenService:Create(rootPart, 
            TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
            {CFrame = CFrame.new(newPos) * rootPart.CFrame.Rotation}
        )
        tween:Play()
        
        -- Efek visual
        local effect = Instance.new("Part")
        effect.Size = Vector3.new(2, 0.5, 2)
        effect.Position = newPos
        effect.BrickColor = BrickColor.new("Really blue")
        effect.Material = Enum.Material.Neon
        effect.CanCollide = false
        effect.Anchored = true
        effect.Parent = workspace
        effect.Transparency = 0.5
        
        game:GetService("Debris"):AddItem(effect, 0.5)
    end
end

local function blinkForward(studs)
    if rootPart and rootPart.Parent then
        local direction = camera.CFrame.LookVector * studs
        local newPos = rootPart.Position + direction
        
        -- Raycast untuk deteksi dinding
        local ray = Ray.new(rootPart.Position, direction)
        local hit, position = workspace:FindPartOnRay(ray, character)
        
        if hit then
            newPos = position - direction.Unit * 2
        end
        
        -- Tween untuk efek halus
        local tween = TweenService:Create(rootPart, 
            TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
            {CFrame = CFrame.new(newPos) * rootPart.CFrame.Rotation}
        )
        tween:Play()
        
        -- Efek visual
        local effect = Instance.new("Part")
        effect.Size = Vector3.new(2, 2, 2)
        effect.Position = newPos
        effect.BrickColor = BrickColor.new("Really blue")
        effect.Material = Enum.Material.Neon
        effect.CanCollide = false
        effect.Anchored = true
        effect.Parent = workspace
        effect.Transparency = 0.5
        effect.Shape = Enum.PartType.Ball
        
        game:GetService("Debris"):AddItem(effect, 0.5)
    end
end

-- Auto Aim Function
local function getNearestTarget()
    local nearest = nil
    local shortestDistance = aimDistance
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") then
                local humanoid = otherChar.Humanoid
                if humanoid.Health > 0 then
                    local otherRoot = otherChar.HumanoidRootPart
                    local distance = (rootPart.Position - otherRoot.Position).Magnitude
                    
                    if distance < shortestDistance then
                        -- Cek line of sight
                        local ray = Ray.new(camera.CFrame.Position, (otherRoot.Position - camera.CFrame.Position).Unit * distance)
                        local hit, pos = workspace:FindPartOnRay(ray, character)
                        
                        if not hit or hit:IsDescendantOf(otherChar) then
                            nearest = otherRoot
                            shortestDistance = distance
                        end
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Auto Aim Loop
RunService.RenderStepped:Connect(function()
    if autoAimEnabled and rootPart and rootPart.Parent then
        local target = getNearestTarget()
        if target then
            currentTarget = target
            local targetPos = target.Position
            camera.CFrame = CFrame.new(camera.CFrame.Position, targetPos)
            
            -- Update status
            aimStatus.Text = "Status: Targeting"
            aimStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            currentTarget = nil
            aimStatus.Text = "Status: No Target"
            aimStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    else
        aimStatus.Text = "Status: Disabled"
        aimStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

-- SLIDER FUNCTIONALITY
local function updateDistanceFromSlider()
    local sliderPos = sliderBtn.AbsolutePosition.X
    local sliderBgPos = sliderBg.AbsolutePosition.X
    local sliderWidth = sliderBg.AbsoluteSize.X
    local relativePos = math.clamp(sliderPos - sliderBgPos, 0, sliderWidth)
    local percentage = relativePos / sliderWidth
    
    aimDistance = math.floor(percentage * 100)
    aimDistance = math.clamp(aimDistance, 10, 200)
    
    distanceLabel.Text = "Distance: " .. aimDistance
    distanceValue.Text = tostring(aimDistance)
end

-- Slider dragging
sliderBtn.MouseButton1Down:Connect(function()
    dragging = true
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation()
        local sliderBgPos = sliderBg.AbsolutePosition.X
        local sliderWidth = sliderBg.AbsoluteSize.X
        local newX = math.clamp(mousePos.X - sliderBgPos, 0, sliderWidth)
        
        sliderBtn.Position = UDim2.new(0, newX - sliderBtn.AbsoluteSize.X/2, 0, -5)
        updateDistanceFromSlider()
    end
end)

