-- Kill Aura & Auto Shoot Loop
RunService.Heartbeat:Connect(function()
    if (killAuraEnabled or autoShootEnabled) and rootPart and rootPart.Parent then
        local targets = getAuraTargets()
        local targetCount = #targets
        
        -- Update status
        local statusText = "Status: "
        if killAuraEnabled and autoShootEnabled then
            statusText = statusText .. "Aura+Shoot"
        elseif killAuraEnabled then
            statusText = statusText .. "Kill Aura"
        elseif autoShootEnabled then
            statusText = statusText .. "Auto Nembak"
        end
        statusText = statusText .. " | Targets: " .. targetCount
        auraStatus.Text = statusText
        
        if targetCount > 0 then
            auraStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
            
            -- Process each target
            for _, target in ipairs(targets) do
                if killAuraEnabled then
                    damageTarget(target)
                end
                
                if autoShootEnabled then
                    shootTarget(target)
                end
            end
        else
            auraStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        
        -- Update visual
        if auraVisualEnabled then
            updateAuraVisual()
        end
    else
        auraStatus.Text = "Status: Disabled | Targets: 0"
        auraStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
        
        -- Clean up visuals
        if not auraVisualEnabled then
            for _, part in ipairs(auraVisualParts) do
                if part and part.Parent then
                    part:Destroy()
                end
            end
            auraVisualParts = {}
        end
    end
end)

